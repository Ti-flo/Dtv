# Copy to .env and fill in your values
# NEVER commit .env to git (it's in .gitignore)

# Bootstrap these once from a logged-in app session via Chrome DevTools (adb forward).
# After each run, test_auth.py / collect.py will auto-rotate them.
DTV_APIKEY=78ab2339-b349-4ed0-9e5c-f52420555e6d
DTV_REFRESH_TOKEN=0af20b4e-6767-4388-8d7e-834c4ac6a4cd

# Account-specific — see ServersListMessage. Confirmed live (canada region):
# 530=Tiliwan 531=Kelerog 532=Blair 533=Talok 411=Tournament
DTV_SERVER_ID=533

# Optional — auto-selects first character if empty
DTV_CHARACTER_ID=
